[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://game/dialogue_demo/scripts/showcase_orchestrator.gd" id="1_orchestrator"]
[ext_resource type="Script" path="res://game/dialogue_demo/scripts/showcase_panel.gd" id="2_panel"]
[ext_resource type="PackedScene" path="res://addons/dialogue_framework/presentation/ui_react_dialogue_hud.tscn" id="3_hud"]

[node name="DialogueShowcase" type="Node"]
script = ExtResource("1_orchestrator")

[node name="ShowcaseUI" type="CanvasLayer" parent="."]
layer = 20

[node name="Panel" type="PanelContainer" parent="ShowcaseUI"]
anchors_preset = 9
anchor_bottom = 1.0
offset_right = 360.0
grow_vertical = 2
script = ExtResource("2_panel")

[node name="Margin" type="MarginContainer" parent="ShowcaseUI/Panel"]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10

[node name="VBox" type="VBoxContainer" parent="ShowcaseUI/Panel/Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Title" type="Label" parent="ShowcaseUI/Panel/Margin/VBox"]
layout_mode = 2
text = "Dialogue Framework"
theme_override_font_sizes/font_size = 18

[node name="Status" type="Label" parent="ShowcaseUI/Panel/Margin/VBox"]
layout_mode = 2
autowrap_mode = 3
text = "Ready."

[node name="ImportStatus" type="Label" parent="ShowcaseUI/Panel/Margin/VBox"]
layout_mode = 2
autowrap_mode = 3
text = "Import status pending..."

[node name="PrimaryRow" type="HBoxContainer" parent="ShowcaseUI/Panel/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Showcase" type="Button" parent="ShowcaseUI/Panel/Margin/VBox/PrimaryRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Interactive Showcase"

[node name="Restart" type="Button" parent="ShowcaseUI/Panel/Margin/VBox/PrimaryRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Restart"

[node name="UtilityRow" type="HBoxContainer" parent="ShowcaseUI/Panel/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="ImportVerify" type="Button" parent="ShowcaseUI/Panel/Margin/VBox/UtilityRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Import Verification"

[node name="SmokeTest" type="Button" parent="ShowcaseUI/Panel/Margin/VBox/UtilityRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Smoke Test"

[node name="ProgressRow" type="HBoxContainer" parent="ShowcaseUI/Panel/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="SaveProgress" type="Button" parent="ShowcaseUI/Panel/Margin/VBox/ProgressRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Save Progress"

[node name="ResumeProgress" type="Button" parent="ShowcaseUI/Panel/Margin/VBox/ProgressRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Resume"

[node name="Locale" type="Button" parent="ShowcaseUI/Panel/Margin/VBox/ProgressRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Français"

[node name="Log" type="RichTextLabel" parent="ShowcaseUI/Panel/Margin/VBox"]
custom_minimum_size = Vector2(0, 140)
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
scroll_following = true
fit_content = false

[node name="Hints" type="Label" parent="ShowcaseUI/Panel/Margin/VBox"]
layout_mode = 2
autowrap_mode = 3
text = "Accept: skip typewriter / advance / confirm choice. Cancel: leave conversation. Arrow keys navigate choices."

[node name="DialogueHUD" parent="." instance=ExtResource("3_hud")]

[connection signal="pressed" from="ShowcaseUI/Panel/Margin/VBox/PrimaryRow/Showcase" to="ShowcaseUI/Panel" method="_on_showcase_pressed"]
[connection signal="pressed" from="ShowcaseUI/Panel/Margin/VBox/PrimaryRow/Restart" to="ShowcaseUI/Panel" method="_on_restart_pressed"]
