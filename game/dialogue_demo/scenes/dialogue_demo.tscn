[connection signal="pressed" from="ShowcaseUI/Panel/Margin/VBox/ProgressRow/ResumeProgress" to="ShowcaseUI/Panel" method="_on_resume_progress_pressed"]
[connection signal="pressed" from="ShowcaseUI/Panel/Margin/VBox/ProgressRow/Locale" to="ShowcaseUI/Panel" method="_on_locale_pressed"]
